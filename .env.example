APP_NAME=BespokeLMS
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
# Production: APP_ENV=production, APP_DEBUG=false, APP_URL=https://app.bespokelms.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_GB

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --- Identity & data: Supabase (single source of truth) --------------------
# The publishable "anon" key is safe to expose to the browser (RLS-protected).
# NEVER commit the service-role key; leave it blank unless a feature needs it.
SUPABASE_URL=https://pqmdtqsscyltykgcwwus.supabase.co
SUPABASE_ANON_KEY=sb_publishable_mqTB-BXLDgPvmF5NgJ_AEQ_8oteU2Rq
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_REDIRECT_URL="${APP_URL}/reset-password"
SUPABASE_HTTP_TIMEOUT=10

# --- Database --------------------------------------------------------------
# The sign-in gate needs no local database (identity comes from Supabase over
# HTTPS). SQLite is a harmless default; point Eloquent at Supabase Postgres
# when the database-driven dashboard is ported in.
DB_CONNECTION=sqlite
# DB_CONNECTION=pgsql
# DB_HOST=db.pqmdtqsscyltykgcwwus.supabase.co
# DB_PORT=5432
# DB_DATABASE=postgres
# DB_USERNAME=postgres
# DB_PASSWORD=

# --- Session (the server-side app gate) ------------------------------------
# Encrypted sessions keep the Supabase tokens server-side only.
# Local dev: file. Production on a scaled/ephemeral host (e.g. Laravel Cloud):
# use 'database' (run `php artisan migrate` to create the sessions table) or redis,
# so sessions are shared across instances and survive redeploys.
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
# Set true in production (HTTPS):
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Password-reset / magic-link email is sent by Supabase Auth, not Laravel mail.
MAIL_MAILER=log
MAIL_FROM_ADDRESS="no-reply@bespokelms.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
